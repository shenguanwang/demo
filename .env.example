# 云平台会自动设置 PORT。
LEAD_TOOL_HOST=0.0.0.0

# 部署完成后填写，例如：
# PUBLIC_BASE_URL=https://your-service.onrender.com
PUBLIC_BASE_URL=

# 不要提交真实密钥，在云平台环境变量中配置。
GOOGLE_MAPS_API_KEY=
YOUTUBE_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=

# 工作台登录。正式部署建议修改默认密码。
APP_USERNAME=admin
APP_PASSWORD=admin123
APP_AUTH_SECRET=replace-with-a-long-random-string

# 云端 PostgreSQL；不配置时本地自动使用 SQLite。
DATABASE_URL=

# 同时执行的获客任务数。免费云实例建议保持 2。
DISCOVERY_MAX_CONCURRENCY=2
NETWORK_DEFAULT_TIMEOUT=12
